{"timestamp":"2026-07-18T13:36:20.403Z","type":"response_item","payload":{"type":"custom_tool_call","id":"ctc_0bd6d73b974b1fab016a5b81544d888191b5c6e352d1f91f65","status":"completed","call_id":"call_A7hJxdc5fJ7BVVj2f6ibPrld","name":"exec","input":"const r = await tools.exec_command({cmd:\"sed -n '1,260p' /private/tmp/brain-bench-graph-agentic-pilot/competitive-eval/tools/test_run_agentic_tasks_smoke.py\\nsed -n '260,620p' /private/tmp/brain-bench-graph-agentic-pilot/competitive-eval/tools/test_run_agentic_tasks_smoke.py\",\"workdir\":\"/Users/thomi/Projects/entire-graph\",\"yield_time_ms\":10000,\"max_output_tokens\":20000});\ntext(r.output);","internal_chat_message_metadata_passthrough":{"turn_id":"019f756f-5147-7222-9084-187ed68d3651"}}}
{"timestamp":"2026-07-18T13:36:20.690Z","type":"response_item","payload":{"type":"custom_tool_call_output","id":"ctco_019f7571-32d2-7093-a3ed-582270208c9d","call_id":"call_A7hJxdc5fJ7BVVj2f6ibPrld","output":[{"type":"input_text","text":"Script completed\nWall time 0.3 seconds\nOutput:\n"},{"type":"input_text","text":"import subprocess\nfrom pathlib import Path\n\nimport run_agentic_tasks_smoke as smoke\n\n\ndef definition(case_id=\"case\"):\n    return {\n        \"id\": case_id,\n        \"category\": \"symbol_discovery\",\n        \"expected\": {\"kind\": \"definition\", \"name\": \"Target\", \"file_path\": \"src/target.py\"},\n    }\n\n\ndef test_definition_scoring_requires_name_and_repository_relative_file():\n    answer = {\"locations\": [{\"name\": \"class Target(Base)\", \"file_path\": \"./src/target.py\", \"line\": 4}]}\n    score = smoke.score_answer(definition(), answer)\n    assert score == {\n        \"id\": \"case\", \"category\": \"symbol_discovery\", \"passed\": True,\n        \"precision\": 1.0, \"recall\": 1.0, \"matched_items\": 1, \"expected_items\": 1,\n    }\n\n\ndef test_callgraph_scoring_reports_partial_quality():\n    case = {\n        \"id\": \"calls\", \"category\": \"direct_callers_callees\",\n        \"expected\": {\"kind\": \"callgraph\", \"items\": [\n            {\"name\": \"One\", \"file_path\": \"a.go\"}, {\"name\": \"Two\", \"file_path\": \"b.go\"},\n        ]},\n    }\n    answer = {\"locations\": [{\"name\": \"One\", \"file_path\": \"a.go\", \"line\": 1}]}\n    score = smoke.score_answer(case, answer)\n    assert not score[\"passed\"]\n    assert score[\"precision\"] == 1.0\n    assert score[\"recall\"] == 0.5\n\n\ndef test_callgraph_extras_do_not_fail_non_exhaustive_authored_expectations():\n    case = {\n        \"id\": \"calls\", \"category\": \"direct_callers_callees\",\n        \"expected\": {\"kind\": \"callgraph\", \"items\": [{\"name\": \"One\", \"file_path\": \"a.go\"}]},\n    }\n    answer = {\"locations\": [\n        {\"name\": \"One (direct call)\", \"file_path\": \"a.go\", \"line\": 1},\n        {\"name\": \"Another legitimate edge\", \"file_path\": \"b.go\", \"line\": 2},\n    ]}\n    assert smoke.score_answer(case, answer)[\"passed\"]\n\n\ndef test_complete_oracle_callgraph_requires_exact_lines_and_no_extras():\n    case = {\n        \"id\": \"calls\", \"category\": \"direct_callers\",\n        \"expected\": {\"kind\": \"callgraph\", \"complete\": True, \"items\": [\n            {\"name\": \"One\", \"file_path\": \"a.go\", \"line\": 10},\n            {\"name\": \"Two\", \"file_path\": \"b.go\", \"line\": 20},\n        ]},\n    }\n    exact = {\"locations\": [\n        {\"name\": \"One\", \"file_path\": \"a.go\", \"line\": 10},\n        {\"name\": \"Two\", \"file_path\": \"b.go\", \"line\": 20},\n    ]}\n    assert smoke.score_answer(case, exact)[\"passed\"]\n    wrong_line = {\"locations\": [*exact[\"locations\"][:1], {\"name\": \"Two\", \"file_path\": \"b.go\", \"line\": 21}]}\n    assert not smoke.score_answer(case, wrong_line)[\"passed\"]\n    with_extra = {\"locations\": [*exact[\"locations\"], {\"name\": \"Extra\", \"file_path\": \"c.go\", \"line\": 30}]}\n    score = smoke.score_answer(case, with_extra)\n    assert not score[\"passed\"]\n    assert score[\"precision\"] == 2 / 3\n\n\ndef test_path_scoring_is_exact_over_symbol_triples():\n    case = {\n        \"id\": \"path\", \"category\": \"transitive_call_path\",\n        \"expected\": {\"kind\": \"call_path\", \"items\": [{\n            \"caller\": {\"name\": \"A\"}, \"focus\": {\"name\": \"B\"}, \"callee\": {\"name\": \"C\"},\n        }]},\n    }\n    answer = {\"paths\": [{\"caller\": \"A\", \"focus\": \"B\", \"callee\": \"C\"}]}\n    assert smoke.score_answer(case, answer)[\"passed\"]\n\n\ndef test_path_scoring_expands_compact_cartesian_families():\n    case = {\n        \"id\": \"path\", \"category\": \"transitive_call_path\",\n        \"expected\": {\"kind\": \"call_path\", \"items\": [\n            {\"caller\": {\"name\": caller}, \"focus\": {\"name\": \"B\"}, \"callee\": {\"name\": callee}}\n            for caller in (\"A1\", \"A2\") for callee in (\"C1\", \"C2\")\n        ]},\n    }\n    answer = {\"path_families\": [{\"callers\": [\"A1\", \"A2\"], \"focus\": \"B\", \"callees\": [\"C1\", \"C2\"]}]}\n    score = smoke.score_answer(case, answer)\n    assert score[\"passed\"]\n    assert score[\"matched_items\"] == 4\n\n\ndef test_complete_oracle_paths_distinguish_same_named_locations():\n    def loc(file_path, line):\n        return {\"name\": \"parse\", \"file_path\": file_path, \"line\": line}\n\n    case = {\n        \"id\": \"path\", \"category\": \"transitive_call_path\",\n        \"expected\": {\"kind\": \"call_path\", \"complete\": True, \"items\": [\n            {\"caller\": loc(\"a.ts\", 1), \"focus\": loc(\"focus.ts\", 5), \"callee\": loc(\"c.ts\", 9)},\n            {\"caller\": loc(\"b.ts\", 2), \"focus\": loc(\"focus.ts\", 5), \"callee\": loc(\"c.ts\", 9)},\n        ]},\n    }\n    answer = {\"path_families\": [{\n        \"callers\": [loc(\"a.ts\", 1), loc(\"b.ts\", 2)],\n        \"focus\": loc(\"focus.ts\", 5), \"callees\": [loc(\"c.ts\", 9)],\n    }]}\n    assert smoke.score_answer(case, answer)[\"passed\"]\n\n\ndef test_missing_structured_response_fails_every_question():\n    scores = smoke.score_response([definition(\"one\"), definition(\"two\")], None)\n    assert [row[\"passed\"] for row in scores] == [False, False]\n\n\ndef test_structured_result_accepts_cli_object_or_json_string():\n    assert smoke.structured_result({\"structured_output\": {\"answers\": []}}) == {\"answers\": []}\n    assert smoke.structured_result({\"result\": '{\"answers\":[]}'}) == {\"answers\": []}\n\n\ndef test_smoke_audit_requires_neighbors_for_graph(monkeypatch):\n    graph = Path(\"/runtime/entire-graph\")\n    monkeypatch.setattr(\n        smoke.runtime,\n        \"audit_treatment\",\n        lambda *_args: {\"passed\": True, \"violations\": []},\n    )\n    monkeypatch.setattr(smoke.runtime, \"bash_command\", lambda tool: tool.get(\"command\", \"\"))\n    missing = smoke.audit_smoke_treatment(\n        \"entire-graph\", [{\"command\": f\"{graph} search --repo . --query x --format agent\"}], graph\n    )\n    assert missing[\"violations\"] == [\"missing_entire_graph_neighbors\"]\n    present = smoke.audit_smoke_treatment(\n        \"entire-graph\", [{\"command\": f\"{graph} neighbors --repo . --symbol X\"}], graph\n    )\n    assert present[\"passed\"]\n    assert present[\"entire_graph_neighbor_calls\"] == 1\n\n\ndef test_pristine_checkout_rejects_dirty_worktree(tmp_path):\n    checkout = tmp_path / \"repo\"\n    smoke.runtime.checked_git([\"init\", \"--quiet\", str(checkout)])\n    smoke.runtime.checked_git([\"config\", \"user.name\", \"Test\"], cwd=checkout)\n    smoke.runtime.checked_git([\"config\", \"user.email\", \"test@example.com\"], cwd=checkout)\n    (checkout / \"source.py\").write_text(\"value = 1\\n\")\n    smoke.runtime.checked_git([\"add\", \"source.py\"], cwd=checkout)\n    smoke.runtime.checked_git([\"commit\", \"--quiet\", \"-m\", \"base\"], cwd=checkout)\n    head = smoke.runtime.checked_git([\"rev-parse\", \"HEAD\"], cwd=checkout).decode().strip()\n    tree = smoke.runtime.checked_git([\"rev-parse\", \"HEAD^{tree}\"], cwd=checkout).decode().strip()\n    repository = {\"repository\": \"example/repo\", \"commit\": head, \"tree\": tree}\n    smoke.assert_pristine_checkout(checkout, repository)\n    (checkout / \"scratch.txt\").write_text(\"not allowed\\n\")\n    try:\n        smoke.assert_pristine_checkout(checkout, repository)\n    except smoke.SmokeError:\n        pass\n    else:\n        raise AssertionError(\"dirty checkout passed the smoke guard\")\n\n\ndef test_smoke_sandbox_checkout_is_read_only(tmp_path):\n    output = tmp_path / \"output\"\n    checkout = output / \"checkouts\" / \"file-tools\"\n    checkout.mkdir(parents=True)\n    source = tmp_path / \"corpus\" / \"repos\" / \"example\"\n    source.mkdir(parents=True)\n    command, _ = smoke.runtime.sandboxed_agent_command(\n        [\"/bin/sh\", \"-c\", \"test -r source.py && ! touch forbidden.txt\"],\n        checkout=checkout,\n        output=output,\n        source_repository=source,\n        readable_files=[],\n        readable_paths=[],\n        writable_paths=[],\n        checkout_writable=False,\n    )\n    (checkout / \"source.py\").write_text(\"value = 1\\n\")\n    subprocess.run(command, cwd=checkout, check=True)\n    assert not (checkout / \"forbidden.txt\").exists()\n\n\ndef test_summary_supports_targeted_single_system_followup(tmp_path):\n    record = {\n        \"repository\": \"example/repo\",\n        \"system\": \"entire-graph\",\n        \"scores\": [{\"passed\": True, \"recall\": 1.0, \"precision\": 1.0, \"matched_items\": 1, \"expected_items\": 1}],\n        \"usage\": {},\n        \"tool_call_count\": 2,\n        \"wall_time_ms\": 100,\n        \"reported_total_cost_usd\": 0.01,\n        \"treatment_audit\": {\"passed\": True},\n    }\n    summary = smoke.summarize([record], tmp_path, (\"entire-graph\",))\n    assert list(summary[\"systems\"]) == [\"entire-graph\"]\n    assert summary[\"attempt_count\"] == 1\n    assert summary[\"repository_count\"] == 1\n    assert summary[\"all_question_exact_claim_allowed\"] is False\n    assert summary[\"callgraph_oracle_complete\"] is False\n    assert summary[\"systems\"][\"entire-graph\"][\"retained_assertion_pass_rate\"] == 1.0\n\n\ndef test_prompt_defines_file_level_and_imported_path_semantics():\n    repository = {\"cases\": [{\"id\": \"case\", \"question\": \"Question?\"}]}\n    prompt = smoke.prompt_for(repository, \"file-tools\", Path(\"/graph\"))\n    assert \"file-level caller\" in prompt\n    assert \"imported or re-exported callee endpoints remain valid\" in prompt\n    assert \"path_families\" in prompt\n    assert \"Cartesian product\" in prompt\n\n\ndef test_oracle_prompt_requires_location_aware_complete_answers():\n    repository = {\"oracle_complete\": True, \"cases\": [{\"id\": \"case\", \"question\": \"Question?\"}]}\n    prompt = smoke.prompt_for(repository, \"file-tools\", Path(\"/graph\"))\n    assert \"four questions\" in prompt\n    assert \"complete compiler-resolved set\" in prompt\n    assert \"Every caller, focus, and callee\" in prompt\n\n\ndef test_both_frozen_smoke_manifests_load():\n    retained = smoke.load_manifest(smoke.DEFAULT_MANIFEST)\n    oracle = smoke.load_manifest(\n        smoke.ROOT / \"competitive-eval\" / \"oracle-agentic-overlay\" / \"manifest.json\"\n    )\n    assert retained[\"suite\"] == smoke.SUITE\n    assert oracle[\"suite\"] == smoke.ORACLE_SUITE\n    converted = smoke.oracle_case(oracle[\"repositories\"][0][\"cases\"][0])\n    assert converted[\"expected\"][\"kind\"] == \"definition\"\n    assert converted[\"expected\"][\"symbol_kind\"] == \"method\"\n"}],"internal_chat_message_metadata_passthrough":{"turn_id":"019f756f-5147-7222-9084-187ed68d3651"}}}
